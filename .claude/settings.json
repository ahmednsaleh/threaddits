{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/ubuntu/bz-workspace/infrastructure/session-continuity/context_gate.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/bin/node\" \"/home/ubuntu/bz-workspace/infrastructure/session-continuity/handover_watch.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}